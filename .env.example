# AssembleAtEase — Required Environment Variables
# Copy this file to .env.local for local development
# All variables must be set in Vercel project settings for production

# ── Upstash Redis (distributed rate limiting) ─────────────────────────────────
# Create a free Redis database at https://console.upstash.com
# Found in Upstash Console > Database > REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in Supabase dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key  # SECRET — never expose to client

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in Stripe dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for development
STRIPE_PUBLISHABLE_KEY=pk_live_...     # used by frontend via /api/config/public-key
STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe Connect webhook signing secret

# ── Resend (email delivery) ───────────────────────────────────────────────────
# Found in Resend dashboard > API Keys
RESEND_API_KEY=re_...

# ── HubSpot (CRM) ─────────────────────────────────────────────────────────────
# Found in HubSpot > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na2-...

# ── Owner / Admin auth ────────────────────────────────────────────────────────
# Used to authenticate requests to /api/booking/complete, cancel, etc.
# Set to a strong random string — keep private
OWNER_PASSWORD=your-strong-owner-password

# ── Cron job auth ─────────────────────────────────────────────────────────────
# Used by Vercel cron jobs to authenticate scheduled requests
# Set to a strong random string — must match Vercel cron config
CRON_SECRET=your-strong-cron-secret

# ── Optional settings ─────────────────────────────────────────────────────────
# Notification email address — defaults to service@assembleatease.com
NOTIFY_EMAIL=service@assembleatease.com

# Google Maps Platform API key (for address autocomplete)
# Found in Google Cloud Console > APIs & Services > Credentials
GOOGLE_MAPS_KEY=AIza...

# Google Review URL shown in completion emails
GOOGLE_REVIEW_URL=https://g.page/r/your-review-link
