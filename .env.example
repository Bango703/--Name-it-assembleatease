# AssembleAtEase environment template
# Copy to .env.local for local development.
# Set production values in Vercel Project Settings. Never commit real secrets.

# Core app services
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESEND_API_KEY=
NOTIFY_EMAIL=service@assembleatease.com
OWNER_PASSWORD=
OWNER_SESSION_SECRET=
ALLOW_LEGACY_OWNER_PASSWORD=false
GUEST_ACCESS_TOKEN_SECRET=
CRON_SECRET=

# Stripe
# Local/dev should use sk_test_/pk_test_ keys.
# Production must use sk_live_/pk_live_ keys from the same Stripe account.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secrets
# STRIPE_WEBHOOK_SECRET: live endpoint for payments, disputes, subscriptions, Connect account updates.
# STRIPE_IDENTITY_WEBHOOK_SECRET: live endpoint for Stripe Identity verification sessions.
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# Required before production can create a positive-price booking. Set true only
# after a Texas tax professional approves service taxability and local sourcing.
TEXAS_TAX_CONFIGURATION_APPROVED=false

# Stripe Connect payouts
# Keep false until live Connect onboarding + transfer testing is proven.
STRIPE_CONNECT_ENABLED=false
STRIPE_CONNECT_LIVE_VALIDATED=false
CONNECT_RETURN_URL=https://www.assembleatease.com/owner
CONNECT_REFRESH_URL=https://www.assembleatease.com/owner
PAYOUT_HOLD_HOURS=24

# Easer membership
# Stripe recurring price ID used by api/assembler/membership.js.
AAE_EASER_MEMBERSHIP=

# Address autocomplete
GEOAPIFY_API_KEY=

# CRM / marketing
HUBSPOT_ACCESS_TOKEN=
GOOGLE_REVIEW_URL=

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:service@assembleatease.com

# Optional owner AI assistant
ANTHROPIC_API_KEY=

# Optional test harness values. Never point these at real customers.
CONNECT_TEST_PROFILE_ID=
CONNECT_TEST_EMAIL=
CONNECT_TEST_AMOUNT_CENTS=12900
CONNECT_MEMBERSHIP_AMOUNT_CENTS=4900
ALLOW_LIVE_STRIPE_KEY=false
