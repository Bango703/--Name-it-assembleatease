{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/repairs",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/junk",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/furniture",
      "destination": "/furniture-assembly-austin-tx",
      "permanent": true
    },
    {
      "source": "/mounting",
      "destination": "/tv-mounting-austin-tx",
      "permanent": true
    },
    {
      "source": "/smarthome",
      "destination": "/smart-home-installation-austin-tx",
      "permanent": true
    },
    {
      "source": "/room-ready-bundles",
      "destination": "/bundles",
      "permanent": true
    },
    {
      "source": "/rewards",
      "destination": "/assemblecash",
      "permanent": true
    },
    {
      "source": "/setupclub",
      "destination": "/setup-club",
      "permanent": true
    },
    {
      "source": "/assembler/earn",
      "destination": "/assembler/apply",
      "permanent": true
    },
    {
      "source": "/blog/junk-removal-cost-austin",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog/home-repairs-diy-vs-hire-austin",
      "destination": "/",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-offers",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/auto-dispatch",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/review-request",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/stale-booking",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/no-show-check",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ops-alert",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/tier-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/reauth-payments",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/auto-blog",
      "schedule": "0 9 1,15 * *"
    },
    {
      "path": "/api/cron/followup",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/release-payouts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/expire-assemblecash",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://js-na2.hs-scripts.com https://js-na2.hs-analytics.net https://js-na2.hs-banner.com https://js-na2.hscollectedforms.net https://www.googletagmanager.com https://www.googletagservices.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com https://hooks.stripe.com https://nominatim.openstreetmap.org https://*.supabase.co wss://*.supabase.co https://api.resend.com https://*.hubspot.com https://forms-na2.hscollectedforms.net https://www.googletagmanager.com https://www.googleadservices.com https://www.google.com; frame-src https://js.stripe.com https://hooks.stripe.com https://js-na2.hs-scripts.com; object-src 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
