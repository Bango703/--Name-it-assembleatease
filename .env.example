# AssembleAtEase environment template
# Copy to .env.local for local development.
# Set production values in Vercel Project Settings. Never commit real secrets.

# Core app services
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESEND_API_KEY=
NOTIFY_EMAIL=service@assembleatease.com
OWNER_PASSWORD=
OWNER_SESSION_SECRET=
ALLOW_LEGACY_OWNER_PASSWORD=false
GUEST_ACCESS_TOKEN_SECRET=
CRON_SECRET=

# Stripe
# Local/dev should use sk_test_/pk_test_ keys.
# Production must use sk_live_/pk_live_ keys from the same Stripe account.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secrets
# STRIPE_WEBHOOK_SECRET: signing secret for the matching test/live payment endpoint.
# Subscribe it to payment_intent.succeeded, payment_intent.amount_capturable_updated,
# payment_intent.payment_failed, payment_intent.canceled, charge.refunded,
# refund.created, refund.updated, refund.failed, and the full charge.dispute
# lifecycle (created, updated, funds_withdrawn, funds_reinstated, closed).
# Add account.updated only when Connect is enabled; add subscription and invoice
# events only when Easer membership billing is deliberately enabled and tested.
# STRIPE_IDENTITY_WEBHOOK_SECRET: signing secret for the matching test/live
# Stripe Identity endpoint (identity.verification_session.verified and
# identity.verification_session.requires_input).
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# Required before production can create a positive-price booking. Set true only
# after a Texas tax professional approves service taxability and local sourcing.
TEXAS_TAX_CONFIGURATION_APPROVED=false

# Stripe Connect payouts
# Keep false until live Connect onboarding + transfer testing is proven.
STRIPE_CONNECT_ENABLED=false
STRIPE_CONNECT_LIVE_VALIDATED=false
CONNECT_RETURN_URL=https://www.assembleatease.com/owner
CONNECT_REFRESH_URL=https://www.assembleatease.com/owner
PAYOUT_HOLD_HOURS=24

# Easer membership
# Keep disabled for launch. Enabling later requires updated contractor terms,
# end-to-end billing/webhook tests, and an explicit owner decision.
EASER_MEMBERSHIP_ENABLED=false
# Stripe recurring price ID used only when EASER_MEMBERSHIP_ENABLED=true.
AAE_EASER_MEMBERSHIP=

# Easer application fee
# The first N qualifying applications may receive the atomic founding waiver.
# Set this once before launch; lowering it later does not revoke recorded waivers.
FOUNDING_EASER_FREE_APPLICATION_LIMIT=20

# Address autocomplete
GEOAPIFY_API_KEY=

# CRM / marketing
HUBSPOT_ACCESS_TOKEN=
GOOGLE_REVIEW_URL=

# Content publishing
# Keep both false until an owner-reviewed blog dry run and a low-risk Buffer
# queue test succeed. AUTO_BLOG_PUBLISH_ENABLED allows writes to the website
# repository; SOCIAL_AUTO_PUBLISH controls Buffer queue creation.
AUTO_BLOG_PUBLISH_ENABLED=false
SOCIAL_AUTO_PUBLISH=false
GITHUB_TOKEN=
BUFFER_API_KEY=
BUFFER_FACEBOOK_CHANNEL_ID=
BUFFER_GOOGLE_BUSINESS_CHANNEL_ID=
BUFFER_LINKEDIN_CHANNEL_ID=
BUFFER_INSTAGRAM_CHANNEL_ID=
BUFFER_POST_MODE=addToQueue
BUFFER_SCHEDULING_TYPE=automatic
BUFFER_ATTACH_IMAGE=true

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:service@assembleatease.com

# Optional owner AI assistant
ANTHROPIC_API_KEY=

# Optional test harness values. Never point these at real customers.
CONNECT_TEST_PROFILE_ID=
CONNECT_TEST_EMAIL=
CONNECT_TEST_AMOUNT_CENTS=12900
CONNECT_MEMBERSHIP_AMOUNT_CENTS=4900
ALLOW_LIVE_STRIPE_KEY=false
